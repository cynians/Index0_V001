{
  "metadata": {
    "name": "Index0 Location Schema",
    "version": 1
  },

  "locations": {

    "location_base": {

      "required": [
        "id",
        "name",
        "type",
        "parent"
      ],

      "base_fields": {

        "id": "string",

        "name": "string",

        "type": "string",

        "parent": ["object", "null"],

        "tags": "array",

        "start_year": ["number", "null"],

        "end_year": ["number", "null"]

      },

      "structural_fields": {

        "neighbours": "array",

        "relationships": "object"

      },

      "knowledge_fields": [

        "introduction",
        "history"

      ]

    },

    "subtypes": {

      "System": {

        "inherits": "location_base",

        "structural_fields": {

          "star": "object",

          "planets": "array",

          "neighbours": "array"

        },

        "structural_definitions": {

          "star": {

            "old_cosmology_name": "string"

          },

          "planet_entry": {

            "designation": "string",

            "name": "string"

          }

        },

        "knowledge_fields": [

          "introduction",
          "history",
          "markets",
          "structures"

        ]

      },

      "Planet": {

        "inherits": "location_base",

        "structural_fields": {

          "orbital_designation": "string",

          "satellite_ids": "array",

          "settlements": "array"

        },

        "structural_definitions": {

          "satellite_entry": {

            "name": "string",

            "id": "string"

          }

        },

        "knowledge_fields": [

          "introduction",
          "environment",
          "biosphere",
          "economy",
          "history"

        ]

      },

      "SurfaceRegion": {

        "inherits": "location_base",

        "structural_fields": {

          "planet": "object",

          "neighbours": "array"

        },

        "knowledge_fields": [

          "introduction",
          "environment",
          "history",
          "economy"

        ]

      },

      "City": {

        "inherits": "location_base",

        "structural_fields": {

          "population": "string",

          "districts": "array"

        },

        "knowledge_fields": [

          "introduction",
          "history",
          "economy",
          "culture"

        ]

      },

      "Site": {

        "inherits": "location_base",

        "structural_fields": {

          "location": "object"

        },

        "knowledge_fields": [

          "introduction",
          "function",
          "history"

        ]

      },

      "OrbitalSector": {

        "inherits": "location_base",

        "structural_fields": {

          "orbit_parent": "object",

          "sector_class": "string",

          "sector_role": "string",

          "altitude_band_km": "object",

          "inclination_band_deg": "object",

          "related_sectors": "array"

        },

        "structural_definitions": {

          "altitude_band_km": {

            "min": ["number", "null"],

            "max": ["number", "null"]

          },

          "inclination_band_deg": {

            "min": ["number", "null"],

            "max": ["number", "null"]

          }

        },

        "knowledge_fields": [

          "introduction",
          "history",
          "formation",
          "traffic_profile",
          "hazards"

        ]

      }

    }

  }

}