{
  "metadata": {
    "name": "Index0 Event Schema",
    "version": 1
  },

  "events": {

    "event_base": {

      "required": [
        "id",
        "name",
        "type",
        "year"
      ],

      "base_fields": {

        "id": "string",

        "name": "string",

        "type": "string",

        "event_class": "string",

        "year": "number",

        "end_year": ["number", "null"],

        "tags": "array"

      },

      "structural_fields": {

        "location": ["object", "null"],

        "participants": "array",

        "factions": "array",

        "related_events": "array",

        "related_technologies": "array",

        "related_vehicles": "array"

      },

      "knowledge_fields": [

        "description",

        "causes",

        "outcomes",

        "historical_significance"

      ]

    }

  }

}