        "associated_events": "array"

      },

      "structural_definitions": {

        "role_entry": {

          "title": "string",

          "organization": ["object", "null"],

          "location": ["object", "null"],

          "start_year": ["number", "null"],

          "end_year": ["number", "null"]

        },

        "relation_entry": {

