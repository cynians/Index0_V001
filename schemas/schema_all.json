{
  "metadata": {
    "name": "World Index Schema",
    "version": 4
  },

  "schemas": {

    "locations": {

      "location_base": {

        "required": [
          "id",
          "name",
          "type",
          "parent"
        ],

        "base_fields": {
          "id": "string",
          "name": "string",
          "type": "string",
          "parent": ["object", "null"],
          "tags": "array",
          "start_year": ["number", "null"],
          "end_year": ["number", "null"]
        },

        "structural_fields": {
          "relationships": "object"
        },

        "knowledge_fields": {
          "introduction": "string",
          "history": "string"
        }

      },

      "subtypes": {

        "System": {

          "inherits": "location_base",

          "structural_fields": {
            "star": "object",
            "planets": "array",
            "neighbours": "array"
          },

          "structural_definitions": {

            "star": {
              "old_cosmology_name": "string"
            },

            "planet_entry": {
              "designation": "string",
              "name": "string"
            },

            "neighbour_entry": {
              "name": "string",
              "id": "string",
              "distance_pcm": "number"
            }

          },

          "knowledge_fields": [
            "introduction",
            "history",
            "markets",
            "structures"
          ],

          "notes": "list"

        },

        "Planet": {

          "inherits": "location_base",

          "structural_fields": {
            "orbital_designation": "string",
            "satellite_ids": "array"
          },

          "structural_definitions": {

            "satellite_entry": {
              "name": "string",
              "id": "string"
            }

          },

          "knowledge_fields": [
            "introduction",
            "environment",
            "biosphere",
            "settlements",
            "economy",
            "history"
          ],

          "notes": "list"

        },

        "OrbitalSector": {

          "inherits": "location_base",

          "structural_fields": {
            "orbit_parent": "object",
            "sector_class": "string",
            "sector_role": "string",
            "altitude_band_km": "object",
            "inclination_band_deg": "object",
            "related_sectors": "array"
          },

          "structural_definitions": {

            "altitude_band_km": {
              "min": ["number", "null"],
              "max": ["number", "null"]
            },

            "inclination_band_deg": {
              "min": ["number", "null"],
              "max": ["number", "null"]
            }

          },

          "knowledge_fields": [
            "introduction",
            "history",
            "formation",
            "traffic_profile",
            "hazards"
          ],

          "notes": "list"

        }

      }

    },

    "species": {

      "species_base": {

        "required": [
          "id",
          "name",
          "type",
          "parent_clade"
        ],

        "base_fields": {
          "id": "string",
          "name": "string",
          "type": "string",
          "parent_clade": ["object", "null"],
          "tags": "array",
          "start_year": ["number", "null"],
          "end_year": ["number", "null"]
        },

        "structural_fields": {
          "habitats": "array",
          "diet": "array",
          "predators": "array",
          "prey": "array"
        },

        "knowledge_fields": [
          "description",
          "behaviour",
          "adaptations",
          "role",
          "evolution"
        ]

      }

    },

    "factions": {

      "faction_base": {

        "required": [
          "id",
          "name",
          "type"
        ],

        "base_fields": {
          "id": "string",
          "name": "string",
          "type": "string",
          "parent_faction": ["object", "null"],
          "tags": "array",
          "start_year": ["number", "null"],
          "end_year": ["number", "null"]
        },

        "structural_fields": {
          "headquarters": "object",
          "territories": "array",
          "members": "array",
          "markets": "array"
        },

        "knowledge_fields": [
          "description",
          "government",
          "culture",
          "history",
          "goals"
        ]

      }

    },

    "people": {

      "person_base": {

        "required": [
          "id",
          "name",
          "type"
        ],

        "base_fields": {
          "id": "string",
          "name": "string",
          "type": "string",
          "birth_year": ["number", "null"],
          "death_year": ["number", "null"],
          "tags": "array"
        },

        "structural_fields": {
          "faction": "object",
          "location": "object",
          "roles": "array",
          "relations": "array"
        },

        "structural_definitions": {

          "role_entry": {
            "title": "string",
            "location": "object",
            "start_year": "number",
            "end_year": ["number", "null"]
          },

          "relation_entry": {
            "person": "object",
            "relation": "string"
          }

        },

        "knowledge_fields": [
          "biography",
          "achievements",
          "personality",
          "history"
        ]

      }

    },

    "events": {

      "event_base": {

        "required": [
          "id",
          "name",
          "type",
          "year"
        ],

        "base_fields": {
          "id": "string",
          "name": "string",
          "type": "string",
          "year": "number",
          "end_year": ["number", "null"],
          "tags": "array"
        },

        "structural_fields": {
          "location": "object",
          "participants": "array",
          "factions": "array",
          "related_events": "array"
        },

        "knowledge_fields": [
          "description",
          "causes",
          "outcomes",
          "historical_significance"
        ]

      }

    },

    "orbital_objects": {

      "orbital_object_base": {

        "required": [
          "id",
          "name",
          "type",
          "orbit_parent"
        ],

        "base_fields": {
          "id": "string",
          "name": "string",
          "type": "string",
          "orbit_parent": "object",
          "orbital_sector": ["object", "null"],
          "ring_number": ["number", "null"],
          "registry_index": ["number", "null"],
          "tags": "array",
          "start_year": ["number", "null"],
          "end_year": ["number", "null"]
        },

        "structural_fields": {
          "origin_event": ["object", "null"],
          "related_objects": "array",
          "orbital_parameters": "object"
        },

        "structural_definitions": {

          "orbital_parameters": {
            "semi_major_axis_km": ["number", "null"],
            "eccentricity": ["number", "null"],
            "inclination_deg": ["number", "null"],
            "longitude_ascending_node_deg": ["number", "null"],
            "argument_periapsis_deg": ["number", "null"],
            "mean_anomaly_deg": ["number", "null"]
          }

        },

        "knowledge_fields": [
          "description",
          "composition",
          "origin",
          "salvage_status"
        ]

      }

    }

  }

}